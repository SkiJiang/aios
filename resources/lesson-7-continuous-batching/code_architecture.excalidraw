    { "type": "text", "id": "free_steps", "x": 1505, "y": 380, "width": 270, "height": 200, "text": "① for state in running_reqs:\n     advance(state, tok)\n     // req.complete_one()\n     // req.generated.append(tok)\n     // mark finished if EOS / max\n② done = DecodeMgr.filter_reqs()\n③ CacheMgr._free(used_pages)\n④ TableMgr.free(req.table_idx)\n⑤ finished.append(state)", "originalText": "① for state in running_reqs:\n     advance(state, tok)\n     // req.complete_one()\n     // req.generated.append(tok)\n     // mark finished if EOS / max\n② done = DecodeMgr.filter_reqs()\n③ CacheMgr._free(used_pages)\n④ TableMgr.free(req.table_idx)\n⑤ finished.append(state)", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#581c87", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 230007, "version": 1, "versionNonce": 230008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.45 },
