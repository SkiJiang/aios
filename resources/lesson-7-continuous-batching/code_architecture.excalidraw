    { "type": "text", "id": "admit_steps", "x": 625, "y": 380, "width": 270, "height": 200, "text": "① head = pending.pop(0)\n② table_idx = TableMgr.allocate()\n③ pages = CacheMgr.allocate(N)\n④ page_table[idx,:N] = pages\n   token_pool[idx,:N] = prompt\n⑤ req   = Req(..., table_idx)\n   state = _ReqState(req, sampler)\n⑥ DecodeMgr.add_req(state)", "originalText": "① head = pending.pop(0)\n② table_idx = TableMgr.allocate()\n③ pages = CacheMgr.allocate(N)\n④ page_table[idx,:N] = pages\n   token_pool[idx,:N] = prompt\n⑤ req   = Req(..., table_idx)\n   state = _ReqState(req, sampler)\n⑥ DecodeMgr.add_req(state)", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#064e3b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 220007, "version": 1, "versionNonce": 220008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.45 },
