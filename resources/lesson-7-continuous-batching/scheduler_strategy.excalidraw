    { "type": "text", "id": "title", "x": 200, "y": 40, "width": 1500, "height": 50, "text": "Scheduling Strategy — Static vs Continuous", "originalText": "Scheduling Strategy — Static vs Continuous", "fontSize": 36, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100001, "version": 1, "versionNonce": 100002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "subtitle", "x": 200, "y": 100, "width": 1500, "height": 25, "text": "Workload: 4 reqs A·B·C·D · output lengths (1, 4, 2, 1) · same prompt length · continuous cap=2", "originalText": "Workload: 4 reqs A·B·C·D · output lengths (1, 4, 2, 1) · same prompt length · continuous cap=2", "fontSize": 16, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100003, "version": 1, "versionNonce": 100004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
