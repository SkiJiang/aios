    { "type": "text", "id": "th_cont_t", "x": 1120, "y": 1583, "width": 730, "height": 22, "text": "CONTINUOUS", "originalText": "CONTINUOUS", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#047857", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 401011, "version": 1, "versionNonce": 401012, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "th_cont", "lineHeight": 1.25 },

    { "type": "text", "id": "r1_a", "x": 75, "y": 1626, "width": 305, "height": 22, "text": "Admission window", "originalText": "Admission window", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 402001, "version": 1, "versionNonce": 402002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "r1_s", "x": 405, "y": 1626, "width": 700, "height": 22, "text": "only once, in init_requests()  →  pending never grows", "originalText": "only once, in init_requests()  →  pending never grows", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 402003, "version": 1, "versionNonce": 402004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "r1_c", "x": 1135, "y": 1626, "width": 715, "height": 22, "text": "every iter, via prefill_manager.schedule_next_batch()", "originalText": "every iter, via prefill_manager.schedule_next_batch()", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 402005, "version": 1, "versionNonce": 402006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

    { "type": "text", "id": "r2_a", "x": 75, "y": 1666, "width": 305, "height": 22, "text": "Loop structure", "originalText": "Loop structure", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 403001, "version": 1, "versionNonce": 403002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "r2_s", "x": 405, "y": 1666, "width": 700, "height": 22, "text": "two distinct phases:  prefill loop  →  decode loop", "originalText": "two distinct phases:  prefill loop  →  decode loop", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 403003, "version": 1, "versionNonce": 403004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "r2_c", "x": 1135, "y": 1666, "width": 715, "height": 22, "text": "single loop with prefill-first dispatch each iter", "originalText": "single loop with prefill-first dispatch each iter", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 403005, "version": 1, "versionNonce": 403006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

