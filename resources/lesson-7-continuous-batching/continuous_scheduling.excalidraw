    { "type": "rectangle", "id": "code_h", "x": 20, "y": 780, "width": 940, "height": 32, "strokeColor": "#1e3a5f", "backgroundColor": "#dbeafe", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 280001, "version": 1, "versionNonce": 280002, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "code_h_t", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "code_h_t", "x": 35, "y": 787, "width": 900, "height": 18, "text": "Dispatch logic — Scheduler.schedule_next_batch()", "originalText": "Dispatch logic — Scheduler.schedule_next_batch()", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 280003, "version": 1, "versionNonce": 280004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "code_h", "lineHeight": 1.25 },
    { "type": "rectangle", "id": "code_box", "x": 20, "y": 818, "width": 940, "height": 200, "strokeColor": "#1e293b", "backgroundColor": "#1e293b", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 280005, "version": 1, "versionNonce": 280006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "code_box_t", "x": 40, "y": 828, "width": 900, "height": 180, "text": "def schedule_next_batch(self):                 # called once per iter\n    # PREFILL-FIRST DISPATCH\n    return (\n        self.prefill_manager.schedule_next_batch(self.max_running)\n        # ↳ if pending and _can_admit(pending[0]):\n        #       allocate slot+pages NOW, build bsz=1 prefill batch\n        or self.decode_manager.schedule_next_batch()\n        # ↳ bundle ALL running_reqs into one decode batch\n    )", "originalText": "def schedule_next_batch(self):                 # called once per iter\n    # PREFILL-FIRST DISPATCH\n    return (\n        self.prefill_manager.schedule_next_batch(self.max_running)\n        # ↳ if pending and _can_admit(pending[0]):\n        #       allocate slot+pages NOW, build bsz=1 prefill batch\n        or self.decode_manager.schedule_next_batch()\n        # ↳ bundle ALL running_reqs into one decode batch\n    )", "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 280007, "version": 1, "versionNonce": 280008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 },

    { "type": "rectangle", "id": "free_h", "x": 1000, "y": 780, "width": 940, "height": 32, "strokeColor": "#047857", "backgroundColor": "#a7f3d0", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 281001, "version": 1, "versionNonce": 281002, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "free_h_t", "type": "text"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "free_h_t", "x": 1015, "y": 787, "width": 900, "height": 18, "text": "Free + admit — process_batch_output() after each iter", "originalText": "Free + admit — process_batch_output() after each iter", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "middle", "strokeColor": "#047857", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 281003, "version": 1, "versionNonce": 281004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "free_h", "lineHeight": 1.25 },
    { "type": "rectangle", "id": "free_box", "x": 1000, "y": 818, "width": 940, "height": 200, "strokeColor": "#1e293b", "backgroundColor": "#1e293b", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 281005, "version": 1, "versionNonce": 281006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "free_box_t", "x": 1020, "y": 828, "width": 900, "height": 180, "text": "def process_batch_output(self, batch, tokens):\n    if batch.is_prefill:\n        advance(batch.admitted_state, tokens[0])\n        if state.finished: self._free_req_resources(state)\n        else:              self.decode_manager.add_req(state)\n    else:                                  # decode batch\n        for state, tok in zip(running_reqs, tokens): advance(state, tok)\n        for done in self.decode_manager.filter_reqs():\n            self._free_req_resources(done)   # ← slot+pages back to pool", "originalText": "def process_batch_output(self, batch, tokens):\n    if batch.is_prefill:\n        advance(batch.admitted_state, tokens[0])\n        if state.finished: self._free_req_resources(state)\n        else:              self.decode_manager.add_req(state)\n    else:                                  # decode batch\n        for state, tok in zip(running_reqs, tokens): advance(state, tok)\n        for done in self.decode_manager.filter_reqs():\n            self._free_req_resources(done)   # ← slot+pages back to pool", "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 281007, "version": 1, "versionNonce": 281008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 },

